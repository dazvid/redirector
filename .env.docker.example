# Copy to .env.docker and fill in real values, then:
#   docker compose --env-file .env.docker up --build

# Postgres (the `db` service). POSTGRES_PASSWORD is required — the
# container refuses to start without it.
POSTGRES_USER=golinks
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=golinks

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=replace-me

# Admin login. Generate the hash with:
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 12))"
# Compose interpolates `$` in .env files, which mangles bcrypt hashes —
# double every literal `$` to `$$` (e.g. $2a$12$abc... -> $$2a$$12$$abc...).
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=replace-me
