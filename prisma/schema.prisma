generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  passwordHash String
  isAdmin      Boolean    @default(false)
  createdAt    DateTime   @default(now())
  shortcuts    Shortcut[]
}

model Shortcut {
  id         String   @id @default(cuid())
  keyword    String   @unique
  url        String
  category   String?
  clickCount Int      @default(0)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  /// Resolved og:image/twitter:image (or favicon) URL, fetched server-side
  /// on create/URL-change. Null if not yet fetched or none was found.
  previewImageUrl  String?
  /// When the preview was last (attempted to be) fetched — lets us tell
  /// "never tried" apart from "tried, found nothing" without refetching
  /// on every read.
  previewFetchedAt DateTime?

  @@index([userId])
}
