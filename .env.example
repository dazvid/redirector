# Database (Postgres). Run
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml --env-file .env.docker up -d db
# for a local instance on localhost:5432, then match its credentials
# here (POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB in .env.docker).
DATABASE_URL="postgresql://golinks:replace-me@localhost:5432/golinks"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-me"

# Admin credentials.
# For production, set ADMIN_PASSWORD_HASH (bcrypt) and remove ADMIN_PASSWORD:
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 12))"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"
# ADMIN_PASSWORD_HASH=""
